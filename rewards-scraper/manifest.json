{
  "manifest_version": 3,
  "name": "Microsoft Rewards Scraper",
  "description": "Chrome Extension for Scraping Microsoft Rewards",
  "version": "1.0.0",
  "content_scripts": [{
    "run_at": "document_end",
    "matches": ["https://rewards.bing.com/redeem/*"],
    "all_frames": false,
    "js": ["content.js"]
  }]
}
